#!/bin/sh
#
# Validate commit message against gitmoji-commit convention.
# Install as .git/hooks/commit-msg to run on every commit.
#
# Usage: validate-commit-msg <commit-message-file>

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Strip comments (lines starting with #)
COMMIT_MSG=$(echo "$COMMIT_MSG" | sed '/^#/d')

# Extract first line (subject)
SUBJECT=$(echo "$COMMIT_MSG" | head -n1)

# --- Checks ---

# Check: subject is not empty
if [ -z "$SUBJECT" ]; then
  echo "ERROR: Commit message is empty." >&2
  exit 1
fi

# Check: subject matches pattern: <emoji> <type>[scope]: <description>
# Emoji unicode range covers common gitmoji
VALID_PATTERN='^[✍✨💥🐛🚑🔒📝💡💄🎨♻🏗⚡✅🧪📦⬆⬇👷💚🔧🚚➕➖🎉⏪🚧🔖☸🌐🧹⚰️🔊🔇🍱💬🥅💫🏳️]: (feat|fix|docs|style|refactor|perf|test|build|ci|chore)(\([a-zA-Z0-9._/-]+\))?!?: .+$'

if echo "$SUBJECT" | grep -qE "$VALID_PATTERN"; then
  : # valid format
else
  # Relaxed check: just ensure it has type+description for better UX
  RELAXED_PATTERN='^[^a-zA-Z]+[ ]?(feat|fix|docs|style|refactor|perf|test|build|ci|chore)(\([a-zA-Z0-9._/-]+\))?!?: .+$'
  if echo "$SUBJECT" | grep -qE "$RELAXED_PATTERN"; then
    : # valid relaxed format
  else
    echo "ERROR: Commit message does not match expected format." >&2
    echo "Expected: <emoji> <type>[scope]: <description>" >&2
    echo "Got:      $SUBJECT" >&2
    echo "Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore" >&2
    exit 1
  fi
fi

# Check: subject length
SUBJECT_LEN=$(echo "$SUBJECT" | wc -m | tr -d ' ')
if [ "$SUBJECT_LEN" -gt 72 ] 2>/dev/null; then
  echo "ERROR: Subject line is ${SUBJECT_LEN} chars (max 72)." >&2
  exit 1
fi

# Check: no generic messages
GENERIC_PATTERN='^(fix stuff|update|changes|minor fixes|bug fixes?|wip)$'
if echo "$SUBJECT" | grep -qiE "$GENERIC_PATTERN"; then
  echo "ERROR: Generic commit message. Be more descriptive." >&2
  exit 1
fi

# Check: breaking changes must have BREAKING CHANGE footer
if echo "$SUBJECT" | grep -q '!:' && ! echo "$COMMIT_MSG" | grep -qi 'BREAKING CHANGE'; then
  echo "ERROR: Breaking change detected ('!:') but no 'BREAKING CHANGE:' footer found." >&2
  exit 1
fi

exit 0
