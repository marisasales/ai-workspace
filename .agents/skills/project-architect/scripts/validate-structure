#!/usr/bin/env python3
"""
Validate project structure against project-architect blueprints.

Usage:
    python validate-structure <project-root> [blueprint-name]
    python validate-structure . python
    python validate-structure . node

If blueprint-name is omitted, auto-detect from project files.
"""

import os
import sys
import json
from pathlib import Path

# ── Blueprint definitions ──────────────────────────────────────────────────

BLUEPRINTS = {
    "python": {
        "label": "Python (Src-Layout)",
        "detect": ["pyproject.toml", "setup.py", "setup.cfg", "requirements.txt"],
        "required": [
            "src",
            "src/*/__init__.py",
            "tests",
            "tests/__init__.py",
            "README.md",
            ".gitignore",
        ],
        "optional": [
            "src/*/main.py",
            "src/*/config.py",
            "src/*/api",
            "src/*/models",
            "src/*/schemas",
            "src/*/services",
            "tests/conftest.py",
            ".env.example",
            ".github/workflows/ci.yml",
        ],
    },
    "node": {
        "label": "Node.js / TypeScript (Express / Fastify)",
        "detect": ["package.json"],
        "required": [
            "src",
            "src/index.ts",
            "package.json",
            "tsconfig.json",
            "README.md",
            ".gitignore",
        ],
        "optional": [
            "src/app.ts",
            "src/config",
            "src/routes",
            "src/controllers",
            "src/services",
            "src/middleware",
            "src/models",
            "src/validators",
            "src/utils",
            "src/types",
            "tests",
            ".env.example",
        ],
    },
    "java": {
        "label": "Java / Kotlin (Spring Boot Layered)",
        "detect": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "required": [
            "src/main/java",
            "src/main/resources",
            "src/test/java",
            "pom.xml",
            "README.md",
            ".gitignore",
        ],
        "optional": [
            "src/main/java/**/config",
            "src/main/java/**/controller",
            "src/main/java/**/dto",
            "src/main/java/**/exception",
            "src/main/java/**/model",
            "src/main/java/**/repository",
            "src/main/java/**/service",
            "src/main/resources/application.yml",
            "src/main/resources/db/migration",
        ],
    },
    "java-ddd": {
        "label": "Java / Kotlin (Spring Boot DDD)",
        "detect": ["pom.xml", "build.gradle", "build.gradle.kts"],
        "required": [
            "src/main/java",
            "src/main/java/**/domain/*/domain/model",
            "src/main/java/**/domain/*/application/service",
            "src/main/java/**/domain/*/infrastructure/persistence",
            "src/main/java/**/domain/*/controller",
            "src/main/java/**/domain/*/dto",
            "src/main/resources",
            "pom.xml",
            "README.md",
            ".gitignore",
        ],
        "optional": [
            "src/main/java/**/shared",
            "src/main/java/**/domain/*/domain/service",
            "src/main/java/**/domain/*/domain/event",
            "src/main/java/**/domain/*/domain/repository",
            "src/main/java/**/domain/*/infrastructure/messaging",
            "src/main/java/**/domain/*/infrastructure/client",
            "src/main/java/**/domain/*/application/port",
            "src/main/resources/application.yml",
            "src/main/resources/db/migration",
            "docker-compose.yml",
        ],
    },
    "frontend-framework": {
        "label": "Frontend — Framework (React / Next.js / Vue + Vite)",
        "detect": ["package.json", "next.config.js", "next.config.ts", "vite.config.ts", "vite.config.js"],
        "required": ["src", "package.json", "README.md", ".gitignore"],
        "optional": [
            "src/components",
            "src/components/common",
            "src/components/layout",
            "src/features",
            "src/hooks",
            "src/styles",
            "src/utils",
            "src/assets",
            "src/app",
            ".env.example",
            "tsconfig.json",
        ],
        "exclude_if": {
            "src/app": "Has `src/app` → likely Next.js App Router",
        },
    },
    "frontend-static": {
        "label": "Frontend — Static (Vanilla HTML / CSS / JS + Vite)",
        "detect": ["index.html", "vite.config.js", "vite.config.ts"],
        "required": ["src", "index.html", "package.json", "README.md", ".gitignore"],
        "optional": [
            "src/assets",
            "src/css",
            "src/css/main.css",
            "src/css/base.css",
            "src/css/components",
            "src/js",
            "src/js/main.js",
            "src/js/components",
            "src/js/utils",
            "src/pages",
        ],
    },
}


def glob_match(pattern: str, root: Path) -> list[Path]:
    """Match a pattern like 'src/*/__init__.py' or 'src/**/config'."""
    parts = pattern.split("/")
    if any("*" in p for p in parts):
        return list(root.glob(pattern))
    path = root / pattern
    return [path] if path.exists() else []


def check_blueprint(root: Path, name: str) -> dict:
    bp = BLUEPRINTS[name]
    results = {"blueprint": bp["label"], "present": [], "missing": [], "warnings": []}

    # Check required
    for pattern in bp["required"]:
        matches = glob_match(pattern, root)
        if matches:
            results["present"].append(pattern)
        else:
            results["missing"].append(pattern)

    # Check optional (info only)
    for pattern in bp.get("optional", []):
        matches = glob_match(pattern, root)
        if matches:
            results["present"].append(f"(opt) {pattern}")

    # Check exclusion hints
    for pattern, hint in bp.get("exclude_if", {}).items():
        if glob_match(pattern, root):
            results["warnings"].append(hint)

    return results


def has_ddd_structure(root: Path) -> bool:
    """Check if a Java project follows DDD structure (has domain/*/domain/model)."""
    return bool(list(root.glob("src/main/java/**/domain/*/domain/model")))


def auto_detect(root: Path) -> str | None:
    # Check DDD Java first (more specific) before Layered Java
    for marker in BLUEPRINTS["java-ddd"]["detect"]:
        if (root / marker).exists() and has_ddd_structure(root):
            return "java-ddd"

    for name, bp in BLUEPRINTS.items():
        for marker in bp["detect"]:
            if (root / marker).exists():
                return name
    return None


def print_report(results: dict, root: Path):
    print(f"\n{'='*60}")
    print(f"  Structure Report: {results['blueprint']}")
    print(f"  Project root: {root}")
    print(f"{'='*60}\n")

    missing = results["missing"]
    present = results["present"]
    warnings = results["warnings"]

    if not missing:
        print("  ✅  All required files/folders present.\n")
    else:
        print(f"  ❌  {len(missing)} required item(s) missing:\n")
        for item in missing:
            print(f"     ✗  {item}")
        print()

    if present:
        print(f"  📁  {len(present)} item(s) found:\n")
        for item in sorted(present):
            print(f"     ✓  {item}")
        print()

    if warnings:
        print("  ⚠️  Notes:\n")
        for w in warnings:
            print(f"     ⚠  {w}")
        print()

    if missing:
        print("  💡 Tip: Run with --json for machine-readable output.\n")


def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    root = Path(args[0]).resolve()
    if not root.is_dir():
        print(f"Error: '{root}' is not a directory.", file=sys.stderr)
        sys.exit(1)

    use_json = "--json" in args

    if len(args) >= 2 and args[1] in BLUEPRINTS:
        blueprint = args[1]
    else:
        detected = auto_detect(root)
        if not detected:
            print("Error: Could not auto-detect project type.", file=sys.stderr)
            print("Specify one: " + ", ".join(BLUEPRINTS.keys()), file=sys.stderr)
            sys.exit(1)
        blueprint = detected
        if not use_json:
            print(f"ℹ  Auto-detected: {BLUEPRINTS[blueprint]['label']}")

    results = check_blueprint(root, blueprint)

    if use_json:
        print(json.dumps(results, indent=2))
    else:
        print_report(results, root)

    sys.exit(1 if results["missing"] else 0)


if __name__ == "__main__":
    main()
